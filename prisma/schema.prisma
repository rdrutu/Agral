// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -----------------------------------------------------------------------------
// Core Models
// -----------------------------------------------------------------------------

model Organization {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  legalName          String?   @map("legal_name")
  registrationNumber String?   @map("registration_number")
  entityType         String?   @default("SRL") @map("entity_type") // SRL, PFA, II, IF, Persoana Fizica
  cui                String?
  caen               String?
  city               String?
  address            String?
  county             String?
  subscriptionTier   String    @default("trial") @map("subscription_tier") // starter, pro, enterprise, trial
  subscriptionStatus String    @default("active") @map("subscription_status")
  maxUsers           Int       @default(1) @map("max_users")
  phone              String?
  activeDiscount     Decimal?  @default(0) @map("active_discount") @db.Decimal(10, 2)
  subscriptionExpiresAt DateTime? @map("subscription_expires_at")
  
  // Locația bazei fermei pentru vreme și hartă
  baseLat           Decimal?  @map("base_lat") @db.Decimal(10, 8)
  baseLng           Decimal?  @map("base_lng") @db.Decimal(10, 8)
  
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  salaryDay          Int?      @default(15) @map("salary_day")

  users              User[]
  parcels            Parcel[]
  seasons            Season[]
  operations         AgriculturalOperation[]
  inventoryItems     InventoryItem[]
  payments           SubscriptionPayment[]
  vehicles           Vehicle[]
  weatherPOIs        WeatherPOI[]
  financialTransactions FinancialTransaction[]
  sales              Sale[]
  leaseContracts     LeaseContract[]

  @@map("organizations")
}

model WeatherPOI {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String   // ex: "Ferma de la deal", "Depozit"
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(10, 8)
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("weather_pois")
}

model SubscriptionPayment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  months    Int
  tier      String
  date      DateTime @default(now())
  amountBeforeDiscount Decimal? @map("amount_before_discount") @db.Decimal(10, 2)
  discountApplied     Decimal? @map("discount_applied") @db.Decimal(10, 2)
  notes     String?

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscription_payments")
}

model Vehicle {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String   // ex: Tractor John Deere
  type            String   // tractor, combine, trailer, pickup
  brand           String?
  model           String?
  year            Int?
  vin             String?  @map("vin_number")
  licensePlate    String?  @map("license_plate")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  maintenanceLogs VehicleMaintenance[]

  // Documente & Termene Limită
  rcaExpiry       DateTime? @map("rca_expiry") @db.Date
  itpExpiry       DateTime? @map("itp_expiry") @db.Date
  cascoExpiry     DateTime? @map("casco_expiry") @db.Date
  rovinietaExpiry DateTime? @map("rovinieta_expiry") @db.Date

  @@map("vehicles")
}

model VehicleMaintenance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId   String   @map("vehicle_id") @db.Uuid
  type        String   // service, fuel, insurance_rca, insurance_casco, itp, other
  date        DateTime
  cost        Decimal? @db.Decimal(10, 2)
  details     String?  // Ex: "Schimb ulei", "Alimentare 200L"
  documentUrl String?  @map("document_url")
  createdAt   DateTime @default(now()) @map("created_at")

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@map("vehicle_maintenance")
}

model User {
  id         String    @id @db.Uuid // Supabase Auth User ID
  orgId      String?   @map("org_id") @db.Uuid
  email      String    @unique
  firstName  String?   @map("first_name")
  lastName   String?   @map("last_name")
  role       String    @default("owner") // owner, superadmin, moderator, agronomist, worker
  canLogin   Boolean   @default(true) @map("can_login")

  // Detalii HR / Salarizare
  monthlySalary Decimal? @map("monthly_salary") @db.Decimal(10, 2) // Brut
  employmentType String? @map("employment_type") // full-time, part-time, seasonal
  salaryDay      Int?    @map("salary_day") // Ziua din lună (1-31)
  dashboardConfig Json? @map("dashboard_config")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastSeen   DateTime? @map("last_seen")
  isSupportActive Boolean @default(false) @map("is_support_active")

  organization Organization? @relation(fields: [orgId], references: [id])
  
  chats        ChatConversation[] @relation("UserChats")
  helpedChats  ChatConversation[] @relation("ModeratorChats")
  messages     ChatMessage[]

  @@map("users")
}

// -----------------------------------------------------------------------------
// Farm Management
// -----------------------------------------------------------------------------

model Parcel {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String    @map("org_id") @db.Uuid
  name          String
  cadastralCode String?   @map("cadastral_code")
  areaHa        Decimal   @map("area_ha") @db.Decimal(10, 2)
  coordinates   Json?     // Format GeoJSON pentru hartă
  soilType      String?   @map("soil_type")
  landUse       String    @default("arabil") @map("land_use") // arabil, pasune, vie, livada
  ownership     String    @default("owned") // owned, rented
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  cropPlans        CropPlan[]
  operationParcels OperationParcel[]
  leaseContracts   LeaseContract[]

  @@map("parcels")
}

model Season {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String   // ex: "Toamnă 2025 - Primăvară 2026"
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date") @db.Date
  isActive    Boolean  @default(false) @map("is_active")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  cropPlans    CropPlan[]

  @@map("seasons")
}

model CropPlan {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seasonId             String    @map("season_id") @db.Uuid
  parcelId             String    @map("parcel_id") @db.Uuid
  cropType             String    @map("crop_type") // grâu, porumb etc.
  variety              String?
  sownAreaHa           Decimal   @map("sown_area_ha") @db.Decimal(10, 2)
  sownDate             DateTime? @map("sown_date") @db.Date
  estimatedHarvestDate DateTime? @map("estimated_harvest_date") @db.Date
  estimatedYieldTha    Decimal?  @map("estimated_yield_t_ha") @db.Decimal(10, 2)
  actualYieldTha       Decimal?  @map("actual_yield_t_ha") @db.Decimal(10, 2)
  status               String    @default("planned") // planned, sown, growing, harvested
  harvestPricePerUnit  Decimal?  @map("harvest_price_per_unit") @db.Decimal(10, 2)

  season               Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  parcel               Parcel    @relation(fields: [parcelId], references: [id], onDelete: Restrict)

  @@map("crop_plans")
  @@index([seasonId])
  @@index([parcelId])
}

// -----------------------------------------------------------------------------
// Agricultural Operations (Modul Lucrări)
// -----------------------------------------------------------------------------

model AgriculturalOperation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  name        String   // Arătură, Semănat, Erbicidat etc.
  type        String?  // semanat, erbicidat, recoltat etc.
  date        DateTime @db.Date
  notes       String?
  totalAreaHa Decimal  @map("total_area_ha") @db.Decimal(10, 2)
  status      String   @default("completed") // planned, in_progress, completed
  yieldPerHa  Decimal? @map("yield_per_ha") @db.Decimal(10, 2)
  totalYield  Decimal? @map("total_yield") @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parcels      OperationParcel[]
  resources    OperationResource[]

  @@map("agricultural_operations")
}

model OperationParcel {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operationId      String  @map("operation_id") @db.Uuid
  parcelId         String  @map("parcel_id") @db.Uuid
  operatedAreaHa   Decimal @map("operated_area_ha") @db.Decimal(10, 2) // Cât din parcelă a fost lucrat

  operation AgriculturalOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  parcel    Parcel                @relation(fields: [parcelId], references: [id], onDelete: Restrict)

  @@map("operation_parcels")
  @@unique([operationId, parcelId])
}

model OperationResource {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operationId      String  @map("operation_id") @db.Uuid
  inventoryItemId  String? @map("inventory_item_id") @db.Uuid // Opțional, legătură cu magazia
  name             String  // ex: Motorină (din stoc sau manual)
  type             String  // combustibil, chimic, samanta, ingrasamant
  quantityPerHa    Decimal @map("quantity_per_ha") @db.Decimal(10, 2)
  totalConsumed    Decimal? @map("total_consumed") @db.Decimal(10, 2) // Cantitatea finala consumată la sfârșitul lucrării
  unit             String  // L, kg, tone
  pricePerUnit     Decimal @map("price_per_unit") @db.Decimal(10, 2)
  
  operation     AgriculturalOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem?        @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)

  @@map("operation_resources")
}

// -----------------------------------------------------------------------------
// Inventory Management (Magazie & Stocuri)
// -----------------------------------------------------------------------------

model InventoryItem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  name            String   // Adengo, Uree, Motorina Standard
  category        String   // combustibil, chimic, ingrasamant, samanta, recolta
  stockQuantity   Decimal  @map("stock_quantity") @db.Decimal(10, 2) @default(0)
  unit            String   // Kg, L, To, etc.
  cropType        String?  // Porumb, Floarea Soarelui, etc. (for seeds and harvests)
  pricePerUnit    Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  lots            InventoryLot[]
  resources       OperationResource[]
  sales           Sale[]

  @@map("inventory_items")
}

model InventoryLot {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  initialQuantity Decimal  @map("initial_quantity") @db.Decimal(10, 2)
  pricePerUnit    Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  source          String   // purchase, harvest
  purchaseDate    DateTime @default(now()) @map("purchase_date")
  expiryDate      DateTime? @map("expiry_date")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  transactions    InventoryTransaction[]

  @@map("inventory_lots")
}

model InventoryTransaction {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inventoryLotId  String   @map("inventory_lot_id") @db.Uuid
  type            String   // intake, consumption, sale, adjustment
  quantity        Decimal  @db.Decimal(10, 2)
  date            DateTime @default(now())
  description     String?
  referenceId     String?  @map("reference_id") // Operation ID or Sale ID

  inventoryLot    InventoryLot @relation(fields: [inventoryLotId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

model FinancialTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  type        String   // income, expense
  category    String   // sale, operation, salary, maintenance, initial_stock, other
  amount      Decimal  @db.Decimal(12, 2)
  date        DateTime @default(now())
  description String?
  referenceId String?  @map("reference_id") // UUID of Sale, Operation, etc.

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("financial_transactions")
}

model Sale {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String   @map("org_id") @db.Uuid
  inventoryItemId String   @map("inventory_item_id") @db.Uuid
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String
  pricePerUnit    Decimal  @map("price_per_unit") @db.Decimal(10, 2)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  buyer           String?
  date            DateTime @default(now())
  notes           String?

  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@map("sales")
}

model LeaseContract {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId             String   @map("org_id") @db.Uuid
  parcelId          String   @map("parcel_id") @db.Uuid
  
  // Detalii Proprietar (Landowner)
  landownerType     String   @default("individual") @map("landowner_type") // individual, company
  landownerName     String   @map("landowner_name")
  landownerCnp      String?  @map("landowner_cnp") // CNP for individual or CUI for company
  landownerFiscalCode String? @map("landowner_fiscal_code") // Alternative for companies
  landownerAddress  String?  @map("landowner_address")
  landownerCiSeries String?  @map("landowner_ci_series")
  landownerCiNumber String?  @map("landowner_ci_number")
  landownerRepresentative String? @map("landowner_representative") // Only for companies
  landownerCounty   String?  @map("landowner_county")
  landownerCity     String?  @map("landowner_city")
  landownerPhone    String?  @map("landowner_phone")
  
  // Detalii Contract
  contractNumber    String   @map("contract_number")
  startDate         DateTime @map("start_date") @db.Date
  endDate           DateTime @map("end_date") @db.Date
  
  // Înregistrare
  registrationCouncil String? @map("registration_council") // Primăria
  registrationCounty  String? @map("registration_county")  // Județul Primăriei
  
  // Termeni Financiari
  pricePerHa        Decimal  @map("price_per_ha") @db.Decimal(10, 2)
  paymentType       String   @default("cash") @map("payment_type") // cash, grain
  paymentStatus     String   @default("pending") @map("payment_status") // paid, pending, partial
  lastPaymentDate   DateTime? @map("last_payment_date")
  
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  organization      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parcel            Parcel       @relation(fields: [parcelId], references: [id], onDelete: Restrict)

  @@map("lease_contracts")
}

// -----------------------------------------------------------------------------
// Live Support & Chat System
// -----------------------------------------------------------------------------

model SupportConfig {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  startHour   Int      @default(8)   // 0-23
  endHour     Int      @default(20)  // 0-23
  isActive    Boolean  @default(true)
  welcomeMsg  String?  @default("Salut, suntem aici să te ajutăm!")
  
  updatedAt   DateTime @updatedAt
  
  @@map("support_configs")
}

model ChatConversation {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid // Client (Farmer)
  moderatorId   String?   @map("moderator_id") @db.Uuid // Assigned Moderator
  status        String    @default("WAITING") // WAITING, ACTIVE, CLOSED
  lastMessageAt DateTime  @default(now()) @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  closedAt      DateTime? @map("closed_at")

  user          User      @relation("UserChats", fields: [userId], references: [id])
  moderator     User?     @relation("ModeratorChats", fields: [moderatorId], references: [id])
  messages      ChatMessage[]

  @@map("chat_conversations")
}

model ChatMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  type           String   @default("USER") // USER, MODERATOR, SYSTEM
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User             @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}
